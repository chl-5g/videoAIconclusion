# 复制为 .env 后按需填写（与 python-dotenv 配合使用）

# 总结步骤：OpenAI 兼容 API（DeepSeek / OpenAI / 多数网关）
OPENAI_API_KEY=
# 可选：默认 https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Ollama: http://127.0.0.1:11434/v1 （API Key 可填任意非空字符串）
OPENAI_BASE_URL=
# 可选：默认 gpt-4o-mini；DeepSeek 示例 deepseek-chat
LLM_MODEL=
